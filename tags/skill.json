[{% for post in site.tags.skill %}{"title":"{{ post.title }}","url":"{{ post.url | absolute_url }}","date":"{{ post.date | date: "%Y-%m-%d" }}","description":"{{ post.description }}","tags":{{ post.tags | jsonify }}{% if post.skill_name %},"skill_name":"{{ post.skill_name }}"{% endif %}{% if post.skill_body %},"skill_body":{{ post.skill_body | jsonify }}{% endif %}}{% unless forloop.last %},{% endunless %}{% endfor %}]
